# RedAgent Configuration
# Copy this file to .env and add your API key

# DeepSeek API Key (required)
# Get your API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_api_key_here

# Optional: Custom proxy sources (comma-separated)
# PROXY_SOURCES=proxyscrape,geonode

# Optional: Default timeout in seconds
# DEFAULT_TIMEOUT=15

# Optional: Maximum proxies to fetch
# MAX_PROXIES=100

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Optional: Data directory (relative to project root)
# DATA_DIR=./data